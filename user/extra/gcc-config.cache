# GCC config.cache for riscv64-unknown-elf cross-compilation
# Prevents configure from running test programs on the target

# Size of basic types
ac_cv_sizeof_void_p=8
ac_cv_sizeof_short=2
ac_cv_sizeof_int=4
ac_cv_sizeof_long=8
ac_cv_sizeof_long_long=8
ac_cv_sizeof_float=4
ac_cv_sizeof_double=8
ac_cv_sizeof_long_double=16
ac_cv_sizeof___int64=0
ac_cv_sizeof_size_t=8
ac_cv_sizeof_ptrdiff_t=8
ac_cv_sizeof_uintptr_t=8
ac_cv_sizeof_ino_t=8
ac_cv_sizeof_dev_t=8
ac_cv_sizeof_ssize_t=8
ac_cv_sizeof_pid_t=4
ac_cv_sizeof_off_t=8
ac_cv_sizeof_time_t=8

# Type existence
ac_cv_type_uint64_t=yes
ac_cv_type_int64_t=yes
ac_cv_type_uint32_t=yes
ac_cv_type_int32_t=yes
ac_cv_type_uintptr_t=yes
ac_cv_type_intptr_t=yes
ac_cv_type_size_t=yes
ac_cv_type_ssize_t=yes
ac_cv_type_ptrdiff_t=yes
ac_cv_type_mode_t=yes
ac_cv_type_pid_t=yes
ac_cv_type_off_t=yes
ac_cv_type_time_t=yes
ac_cv_type_ino_t=yes
ac_cv_type_dev_t=yes
ac_cv_type_long_long=yes
ac_cv_type_unsigned_long_long=yes

# intmax types
ac_cv_type_intmax_t=yes
ac_cv_type_uintmax_t=yes
gcc_cv_type_intmax_t=yes

# Byte order
ac_cv_c_bigendian=no

# Compiler characteristics
ac_cv_prog_cc_c99=yes
ac_cv_prog_cc_c11=yes
ac_cv_prog_cc_stdc=yes

# C library features
ac_cv_func_malloc_0_nonnull=yes
ac_cv_func_realloc_0_nonnull=yes
ac_cv_func_memcmp_working=yes
ac_cv_func_stat_empty_string_bug=no
ac_cv_func_lstat_empty_string_bug=no

# For libcpp
ac_cv_func_clearerr=yes
ac_cv_func_fclose=yes
ac_cv_func_ferror=yes
ac_cv_func_fflush=yes
ac_cv_func_fgetc=yes
ac_cv_func_fgetpos=yes
ac_cv_func_fgets=yes
ac_cv_func_fopen=yes
ac_cv_func_fprintf=yes
ac_cv_func_fputc=yes
ac_cv_func_fputs=yes
ac_cv_func_fread=yes
ac_cv_func_free=yes
ac_cv_func_fseek=yes
ac_cv_func_fsetpos=yes
ac_cv_func_ftell=yes
ac_cv_func_fwrite=yes
ac_cv_func_getc=yes
ac_cv_func_getenv=yes
ac_cv_func_malloc=yes
ac_cv_func_memcpy=yes
ac_cv_func_memmove=yes
ac_cv_func_memset=yes
ac_cv_func_printf=yes
ac_cv_func_putc=yes
ac_cv_func_realloc=yes
ac_cv_func_rename=yes
ac_cv_func_setbuf=yes
ac_cv_func_setvbuf=yes
ac_cv_func_snprintf=yes
ac_cv_func_sprintf=yes
ac_cv_func_sscanf=yes
ac_cv_func_strchr=yes
ac_cv_func_strerror=yes
ac_cv_func_strlen=yes
ac_cv_func_strncmp=yes
ac_cv_func_strncpy=yes
ac_cv_func_strrchr=yes
ac_cv_func_strstr=yes
ac_cv_func_strtol=yes
ac_cv_func_strtoul=yes
ac_cv_func_tmpfile=yes
ac_cv_func_tmpnam=yes
ac_cv_func_ungetc=yes
ac_cv_func_vfprintf=yes
ac_cv_func_vprintf=yes
ac_cv_func_vsprintf=yes
ac_cv_func_vsnprintf=yes

# Headers
ac_cv_header_stdc=yes
ac_cv_header_stdint_h=yes
ac_cv_header_inttypes_h=yes
ac_cv_header_stdlib_h=yes
ac_cv_header_string_h=yes
ac_cv_header_strings_h=yes
ac_cv_header_sys_stat_h=yes
ac_cv_header_sys_types_h=yes
ac_cv_header_unistd_h=yes
ac_cv_header_stdio_h=yes
ac_cv_header_errno_h=yes
ac_cv_header_fcntl_h=yes
ac_cv_header_limits_h=yes
ac_cv_header_locale_h=yes
ac_cv_header_signal_h=yes
ac_cv_header_stdarg_h=yes
ac_cv_header_stddef_h=yes
ac_cv_header_time_h=yes
ac_cv_header_wchar_h=yes
ac_cv_header_sys_file_h=yes
ac_cv_header_sys_mman_h=yes
ac_cv_header_sys_param_h=yes
ac_cv_header_sys_resource_h=yes
ac_cv_header_sys_time_h=yes
ac_cv_header_sys_wait_h=yes

# Target-specific for GCC's own configure
gcc_cv_declare_missing_errno=no
gcc_cv_libc_provides_ssp=no
